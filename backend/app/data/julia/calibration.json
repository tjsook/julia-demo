    "S": {
      "kind": "flat",
      "value": 0.1,
      "source": "industry midpoint"
    },
    "P": {
      "kind": "linear",
      "multiplier": 0.142857,
      "divisor": 7,
      "min": 1,
      "round": "ceil",
      "source": "manual capacity ~5-8 trucks/dispatcher"
    },
    "Ld": {
      "kind": "linear",
      "multiplier": 0.55,
      "source": "MD example anchor"
    },
    "Du": {
      "kind": "flat",
      "value": 0.5,
      "source": "ATRI uncollected detention"
    },
    "R": {
      "kind": "flat",
      "value": 2300,
      "source": "default revenue per load"
    }
