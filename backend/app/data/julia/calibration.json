    "Di": {
      "value": 0.18,
      "label": "Loads with billable detention",
      "unit": "ratio",
      "calibrated": false
    },
    "Hb": {
      "value": 1.5,
      "label": "Billable detention hours per event",
      "unit": "hours",
      "calibrated": false
    },
    "Dr": {
      "value": 50,
      "label": "Detention rate per hour",
      "unit": "usd_per_hour",
      "calibrated": false
    },
    "Lc": {
      "value": 55000,
      "label": "Loaded annual cost per office head",
      "unit": "usd",
      "calibrated": false
    },
    "Oa": {
      "value": 0.3,
      "label": "Office labor automated share",
      "unit": "ratio",
      "calibrated": false
    },
    "G": {
      "value": 16000,
