      "loads",
      "drivers",
      "office",
      "dispatchers",
      "detention",
      "spot",
      "contracted",
      "fleet",
      "fuel",
      "billed",
      "freight",
      "dock",
      "tenders",
      "miles",
      "gallons"
    ],
    "roi_verb_patterns": [
      "analyze",
      "run an analysis",
      "run analysis",
      "synthesize a report",
      "synthesize report",
      "calculate roi",
      "do an roi",
      "do roi",
      "run the numbers",
      "give me an analysis"
    ],
    "doc_word_triggers": [
